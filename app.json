{
  "expo": {
    "name": "Delta Check Scanner",
    "slug": "delta-check-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/deltaplus.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deltacheckscanner.app"
    },
    "android": {
      "package": "com.deltacheckscanner.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to scan check images.",
          "cameraPermission": "The app accesses your camera to take photos of checks."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8089dcc2-3e59-46fa-b74b-5e77eb025e78"
      }
    }
  }
}
